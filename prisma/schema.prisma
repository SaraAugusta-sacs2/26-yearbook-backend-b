// Datasource — conexão com o banco PostgreSQL no Neon
datasource db {
  provider = "postgresql"           // tipo de banco
  url      = env("DATABASE_URL")    // lê a URL do arquivo .env
}

// Generator — gera o Prisma Client em JavaScript
generator client {
  provider = "prisma-client-js"
}

// Enum — valores fixos para o campo role
enum Role {
  USER    // aluno comum
  ADMIN   // administrador (professor ou aluno com permissão especial)
}

// Model Mensagem - representa a tabela "Mensagem" no banco
model Mensagem {
  id            Int        @id @default(autoincrement())  // PK, autoincrement
  texto         String                                    // O conteúdo da mensagem
  imagemURL     String?                                   // URL da imagem(opcional)
  autorId       Int                                       // FK → Aluno (quem escreveu)
  autor         Aluno      @relation(fields: [autorId], references: [id]) //Relação com o model Aluno
  criadoEm      DateTime   @default(now())                 //  Data de criação automática                              
}
// Model Aluno — representa a tabela "Aluno" no banco
model Aluno {
  id            Int        @id @default(autoincrement())   // PK, gerado automaticamente
  nome          String                                     // obrigatório
  email         String     @unique                         // obrigatório e único
  senhaHash     String                                     // hash da senha (nunca retornado pela API)
  cidade        String?                                    // opcional
  frase         String?                                    // opcional
  planosFuturos String?                                    // opcional
  fotoUrl       String?                                    // opcional (URL do Uploadcare)
  role          Role       @default(USER)                  // USER por padrão
  criadoEm      DateTime   @default(now())                 // data de criação automática
  mensagens     Mensagem[]                               // relação 1:N — um aluno tem muitas mensagens
}